[
  {
    "id": "sports-ai-001",
    "text": "I'd rather have more heart than talent any day.",
    "author": "Allen Iverson",
    "character": "The Answer",
    "source": "Interview",
    "sourceType": "interview",
    "year": null,
    "isbn": null,
    "url": "https://en.wikiquote.org/wiki/Allen_Iverson",
    "videoUrl": null,
    "tags": ["heart", "hustle", "talent", "authenticity"],
    "language": "en",
    "mood": "inspirational",
    "maxDisplayLength": "short",
